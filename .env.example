APP_NAME="Kemerbet Agents"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_TIMEZONE=Africa/Addis_Ababa

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kemerbet_agents
DB_USERNAME=kemerbet
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=2

SANCTUM_STATEFUL_DOMAINS=localhost:5174,localhost:8001
SESSION_DOMAIN=localhost

CORS_ALLOWED_ORIGINS="http://localhost:5174,http://localhost:8001"

KEMERBET_PUBLIC_CACHE_TTL=30
KEMERBET_AGENT_HIDE_AFTER_HOURS=12
KEMERBET_TOKEN_LENGTH=64
KEMERBET_DEFAULT_PREFILL_MESSAGE="Hi Kemerbet agent, I want to deposit"

VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@kemerbet.com

VITE_APP_NAME="${APP_NAME}"
